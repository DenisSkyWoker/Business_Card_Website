ax-width: 900px;\n    margin: 0 auto;\n    position: relative;\n    z-index: 1;\n}\n\n.faq-item {\n    background: rgba(255, 255, 255, 0.95);\n    backdrop-filter: blur(10px);\n    border-radius: var(--radius-lg);\n    overflow: hidden;\n    margin-bottom: 16px;\n    border: 1px solid rgba(255, 255, 255, 0.2);\n    transition: all 0.3s ease;\n}\n\n.faq-item:hover {\n    box-shadow: var(--shadow-md);\n    transform: translateY(-2px);\n    border-color: var(--primary-light);\n}\n\n.faq-item__title {\n    padding: 24px;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    font-weight: 600;\n    justify-content: space-between;\n    transition: all 0.3s ease;\n    color: var(--text-color);\n}\n\n.faq-item__title:hover { background: var(--primary-light); }\n\n.faq-item__title i:first-child {\n    color: var(--primary-color);\n    font-size: 1.3rem;\n}\n\n.faq-item__title .fa-chevron-down {\n    transition: transform 0.4s ease;\n    font-size: 0.9rem;\n    color: var(--gray-400);\n}\n\n.faq-item.active .fa-chevron-down {\n    transform: rotate(180deg);\n    color: var(--primary-color);\n}\n\n.faq-item__text {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.4s ease-out, padding 0.4s ease;\n    padding: 0 24px;\n    background: var(--gray-100);\n}\n\n.faq-item.active .faq-item__text {\n    max-height: 300px;\n    padding: 0 24px 24px;\n}\n\n.faq-item__text p {\n    color: var(--gray-600);\n    line-height: 1.8;\n    margin-top: 16px;\n}\n\n/* --- Контакты --- */\n.home-contact {\n    padding: 100px 0;\n    position: relative;\n    overflow: hidden;\n    background-image: url('../bg-garage/contacts-bg.jpg');\n    background-size: cover;\n    background-position: center;\n    background-repeat: no-repeat;\n    background-attachment: fixed;\n}\n\n.home-contact::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: linear-gradient(135deg, rgba(30, 41, 59, 0.9) 0%, rgba(45, 55, 72, 0.85) 100%);\n    z-index: 0;\n}\n\n.home-contact .container {\n    position: relative;\n    z-index: 1;\n}\n\n.home-contact__wrapper {\n    margin-bottom: 48px;\n    position: relative;\n    z-index: 1;\n}\n\n.home-contact__items {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));\n    gap: 32px;\n    position: relative;\n    z-index: 1;\n}\n\n.home-contact__item {\n    padding: 20px 24px;\n    background: rgba(255, 255, 255, 0.95);\n    backdrop-filter: blur(10px);\n    border-radius: var(--radius-md);\n    border: 1px solid rgba(255, 255, 255, 0.2);\n    transition: all 0.3s ease;\n}\n\n.home-contact__item:hover {\n    box-shadow: var(--shadow-md);\n    transform: translateY(-3px);\n    border-color: var(--primary-light);\n}\n\n.home-contact__item-title {\n    font-weight: 700;\n    margin-bottom: 10px;\n    color: var(--primary-color);\n    text-transform: uppercase;\n    font-size: 11px;\n    letter-spacing: 1.5px;\n    line-height: 1.4;\n}\n\n.home-contact__item-text {\n    color: var(--text-color);\n    font-size: 14px;\n    line-height: 1.6;\n}\n\n.home-contact__item-text a {\n    color: var(--text-color);\n    font-weight: 600;\n    text-decoration: none;\n    transition: all 0.3s ease;\n    display: table;\n    align-items: center;\n    gap: 6px;\n}\n\n.home-contact__item-text a:hover {\n    color: var(--primary-color);\n}\n\n.home-contact__item-soc {\n    display: flex;\n    gap: 12px;\n    flex-wrap: wrap;\n}\n\n.home-contact__item-soc a {\n    width: 40px;\n    height: 40px;\n    background: var(--gray-100);\n    border-radius: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 16px;\n    color: var(--text-color);\n    transition: all 0.3s ease;\n}\n\n.home-contact__item-soc a:hover {\n    background: var(--primary-color);\n    color: var(--white);\n    transform: translateY(-3px);\n}\n\n.avito-btn {\n    background: linear-gradien