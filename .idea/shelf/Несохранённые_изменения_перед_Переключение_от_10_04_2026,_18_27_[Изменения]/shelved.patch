00;\n    margin-bottom: 16px;\n    font-size: 1rem;\n}\n\n.footer-contact__phone {\n    display: block;\n    font-size: 1.3rem;\n    color: var(--white);\n    margin-bottom: 20px;\n    font-weight: 700;\n}\n\n.footer-contact__btn { width: 100%; }\n\n.footer-menu__title,\n.footer-pays__title {\n    color: var(--white);\n    font-weight: 600;\n    margin-bottom: 20px;\n    font-size: 1rem;\n}\n\n.footer-menu__nav ul li { margin-bottom: 12px; }\n.footer-menu__nav ul li a { color: var(--gray-400); transition: all 0.3s ease; }\n.footer-menu__nav ul li a:hover { color: var(--primary-color); padding-left: 8px; }\n\n.payment-icons {\n    display: flex;\n    gap: 16px;\n    font-size: 2.2rem;\n    color: var(--gray-400);\n}\n\n.footer-bottom {\n    border-top: 1px solid rgba(255,255,255,0.1);\n    padding-top: 24px;\n}\n\n.footer-bottom__list {\n    display: flex;\n    justify-content: space-between;\n    flex-wrap: wrap;\n    gap: 16px;\n}\n\n/* --- Модальное окно --- */\n.modal {\n    display: none;\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100vh;\n    z-index: 2000;\n}\n\n.modal.active {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.modal-overlay {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: rgba(30, 41, 59, 0.8);\n    backdrop-filter: blur(4px);\n}\n\n.modal-list { position: relative; z-index: 2001; }\n\n.modal-container {\n    background: var(--white);\n    padding: 48px 40px;\n    border-radius: var(--radius-xl);\n    max-width: 480px;\n    width: 90%;\n    box-shadow: var(--shadow-xl);\n    animation: fadeInUp 0.4s ease-out;\n}\n\n.modal-close {\n    position: absolute;\n    top: 20px;\n    right: 24px;\n    font-size: 1.5rem;\n    cursor: pointer;\n    color: var(--gray-400);\n    transition: 0.3s;\n}\n\n.modal-close:hover { color: var(--text-color); }\n\n.modal-title {\n    font-size: 1.6rem;\n    margin-bottom: 32px;\n    text-align: center;\n    color: var(--text-color);\n    font-weight: 700;\n}\n\n.modal-form .consultation-item {\n    position: relative;\n    margin-bottom: 24px;\n}\n\n.modal-form input {\n    width: 100%;\n    padding: 16px 20px;\n    padding-left: 50px;\n    border: 2px solid var(--gray-200);\n    border-radius: var(--radius-md);\n    font-size: 14px;\n    transition: all 0.3s ease;\n    font-family: inherit;\n}\n\n.modal-form input:focus {\n    outline: none;\n    border-color: var(--primary-color);\n    box-shadow: 0 0 0 4px var(--primary-light);\n}\n\n.consultation-item__icon {\n    position: absolute;\n    left: 18px;\n    top: 50%;\n    transform: translateY(-50%);\n    color: var(--gray-400);\n    font-size: 1.1rem;\n}\n\n.modal-form__btn { width: 100%; }\n\n.modal-form__policy {\n    font-size: 0.8rem;\n    color: var(--gray-500);\n    text-align: center;\n    margin-top: 20px;\n    line-height: 1.6;\n}\n\n.modal-form__policy a { color: var(--primary-color); }\n\n/* --- Кнопка Наверх --- */\n.scroll-top {\n    position: fixed;\n    bottom: 32px;\n    right: 32px;\n    width: 56px;\n    height: 56px;\n    background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));\n    color: var(--white);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    opacity: 0;\n    visibility: hidden;\n    transition: all 0.4s ease;\n    z-index: 995;\n    box-shadow: var(--shadow-lg);\n    font-size: 1.2rem;\n}\n\n.scroll-top.show {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0);\n}\n\n.scroll-top:hover {\n    transform: translateY(-4px);\n    box-shadow: var(--shadow-xl);\n}\n\n/* --- Чат-бот --- */\n.chatbot {\n    position: fixed;\n    bottom: 110px;\n    right: 32px;\n    width: 380px;\n    background: var(--white);\n    border-radius: var(--radius-xl);\n    box-shadow: var(--shadow-xl);\n    z-index: 1000;\n    overflow: hidden;\n    display: none;\n    border: 1