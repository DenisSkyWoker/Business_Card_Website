after { opacity: 1; }\n\n.gallery-caption {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n    background: rgba(0,0,0,0.8);\n    color: var(--white);\n    padding: 16px;\n    text-align: center;\n    font-size: 0.95rem;\n    font-weight: 500;\n    transform: translateY(100%);\n    transition: transform 0.4s ease;\n}\n\n.gallery-item:hover .gallery-caption { transform: translateY(0); }\n\n/* --- Отзывы --- */\n.home-reviews {\n    padding: 100px 0;\n    position: relative;\n    overflow: hidden;\n    background-image: url('../bg-garage/reviews-bg.jpg');\n    background-size: cover;\n    background-position: center;\n    background-repeat: no-repeat;\n    background-attachment: fixed;\n}\n\n.home-reviews::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: linear-gradient(135deg, rgba(30, 41, 59, 0.9) 0%, rgba(45, 55, 72, 0.85) 100%);\n    z-index: 0;\n}\n\n.home-reviews .container {\n    position: relative;\n    z-index: 1;\n}\n\n.home-reviews__wrapper { position: relative; z-index: 1; }\n.home-reviews__slider { overflow: hidden; position: relative; z-index: 1; }\n\n.home-reviews__item {\n    background: rgba(255, 255, 255, 0.95);\n    backdrop-filter: blur(10px);\n    padding: 40px 32px;\n    border-radius: var(--radius-xl);\n    margin: 10px;\n    border: 1px solid rgba(255, 255, 255, 0.2);\n    transition: all 0.4s ease;\n}\n\n.home-reviews__item:hover {\n    box-shadow: var(--shadow-lg);\n    transform: translateY(-4px);\n    border-color: var(--primary-light);\n}\n\n.reviews-item__top {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 20px;\n}\n\n.reviews-item__title {\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: var(--text-color);\n}\n\n.reviews-item__stars {\n    color: var(--accent-color);\n    font-size: 1.2rem;\n}\n\n.reviews-item__text {\n    font-style: italic;\n    color: var(--gra